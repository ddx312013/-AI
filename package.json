{
  "name": "carhome",
  "version": "0.2.0",
  "type": "module",
  "description": "carhome 汽车图片图审识别（启发式 baseline + Gemini VLM 可插拔分析）",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenlabSimon/carhome.git"
  },
  "bugs": {
    "url": "https://github.com/OpenlabSimon/carhome/issues"
  },
  "homepage": "https://github.com/OpenlabSimon/carhome#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "batch-eval": "node scripts/batch-eval.js",
    "docker:build": "docker build -t carhome:latest .",
    "docker:run": "docker run --rm -p 3100:3100 --env-file .env.local carhome:latest",
    "review-checklist": "node scripts/generate-review-checklist.js",
    "reviewed-eval": "node scripts/reviewed-eval.js",
    "review-sync": "node scripts/sync-review-annotations.js",
    "provider:diagnose": "node scripts/provider-diagnose.js",
    "start:prod": "HOST=0.0.0.0 NODE_ENV=production node server.js",
    "start": "node server.js",
    "self-test": "node scripts/self-test.js",
    "self-test:runtime": "node scripts/runtime-self-test.js",
    "self-test:live": "node scripts/live-test.js"
  }
}
